{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dulzumat",
  "compatibility_date": "2026-03-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "build": {
      "command": "hugo --gc --minify --buildFuture -b https://dulzumat.jorge-cae.workers.dev"
    },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
